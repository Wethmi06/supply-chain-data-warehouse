      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6C7C4A1F-906F-4B1C-8CB4-67E7AEFF8944}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET &#xA;    accm_txn_create_time = s.OrderDate,&#xA;    accm_txn_complete_time = s.ShippingDate,&#xA;    txn_process_time_hours = DATEDIFF(HOUR, s.OrderDate, s.ShippingDate)&#xA;FROM FactOrderItem f&#xA;JOIN SupplyChainStaging.dbo.StgOrders s&#xA;    ON f.OrderItemId = s.OrderItemId&#xA;WHERE f.accm_txn_complete_time IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
