            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/ \\MSSQLSERVER2;SupplyChainDW\",",
                "    dbo_FactOrderItem = Source{[Schema=\"dbo\",Item=\"FactOrderItem\"]}[Data]",
