                "    dbo_FactOrderItem"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Total Sales",
            "expression": "SUM(FactOrderItem[Sales])"
          },
          {
            "name": "Total Profit",
            "expression": "SUM(FactOrderItem[OrderProfitPerOrder])"
          },
          {
            "name": "Total Orders",
            "expression": "DISTINCTCOUNT(FactOrderItem[OrderId])"
          },
          {
            "name": "Total Quantity",
            "expression": "SUM(FactOrderItem[OrderItemQuantity])"
          },
          {
            "name": "Avg Shipping Days",
            "expression": "AVERAGE(FactOrderItem[DaysShippingReal])"
          },
          {
            "name": "Late Delivery Count",
            "expression": "CALCULATE(COUNTROWS(FactOrderItem),FactOrderItem[LateDeliveryRisk]=1)"
          },
          {
            "name": "Late Delivery %",
            "expression": "DIVIDE([Late Delivery Count],[Total Orders],0)*100",
            "kpi": {
              "targetExpression": "50",
              "statusGraphic": "Traffic Light - Single",
              "statusExpression": [
                "var x='FactOrderItem'[Late Delivery %] return",
                "            if(ISBLANK(x),BLANK(),",
                "                    If(x<30,-1,",
                "\t                If(x<50,0,1)",
                "                )",
                "            )",
                "            "
              ],
              "annotations": [
                {
                  "name": "GoalType",
                  "value": "StaticValue"
                },
                {
                  "name": "KpiStatusType",
                  "value": "Linear"
                },
                {
                  "name": "KpiThresholdType",
                  "value": "Absolute"
                },
                {
                  "name": "KpiThresholdOrdering",
                  "value": "Ascending"
                },
                {
                  "name": "KpiThresholdCount",
                  "value": "2"
                },
                {
                  "name": "KpiThreshold_0",
                  "value": "30"
                },
                {
                  "name": "KpiThreshold_1",
                  "value": "50"
                }
              ]
            }
          }
        ]
